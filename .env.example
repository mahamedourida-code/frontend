# ============================================
# AXLINER FRONTEND ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env.local and fill in your actual values
# Never commit .env.local to version control

# --------------------------------------------
# Supabase Configuration
# --------------------------------------------
# Get these from: https://app.supabase.com/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key-here
SUPABASE_JWT_SECRET=your-supabase-jwt-secret-here

# --------------------------------------------
# Backend API Configuration
# --------------------------------------------
# Your FastAPI backend URL (Fly.io deployment)
NEXT_PUBLIC_API_URL=https://your-backend-app.fly.dev
NEXT_PUBLIC_WS_URL=wss://your-backend-app.fly.dev

# --------------------------------------------
# OAuth Providers (Optional)
# --------------------------------------------
# NOTE: OAuth credentials are primarily configured in Supabase Dashboard
# under Authentication > Providers. These environment variables are optional
# and only needed if you want to use them client-side for specific features.

# Google OAuth
# Get from: https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here

# Facebook OAuth
# Get from: https://developers.facebook.com/apps/
NEXT_PUBLIC_FACEBOOK_APP_ID=your-facebook-app-id-here

# GitHub OAuth
# Get from: https://github.com/settings/developers
# Configure these in Supabase Dashboard, not here
# GITHUB_CLIENT_ID=your-github-client-id-here
# GITHUB_CLIENT_SECRET=your-github-client-secret-here

# --------------------------------------------
# Setup Instructions
# --------------------------------------------
# 1. Copy this file: cp .env.example .env.local
# 2. Fill in your Supabase credentials (required)
# 3. Fill in your backend API URL (required)
# 4. Configure OAuth providers in Supabase Dashboard (see steps_github.md)
# 5. Optionally add OAuth client IDs here if needed for client-side features
# 
# For detailed OAuth setup instructions, see: steps_github.md
